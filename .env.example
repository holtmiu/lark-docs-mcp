# MCP HTTP server for remote clients such as ChatGPT custom connector / MCP clients.
MCP_HTTP_ADDR=:8080
# Required for remote /mcp by default. Leave empty only with MCP_ALLOW_UNAUTHENTICATED=true for local development.
MCP_SERVER_API_KEY=
MCP_ALLOW_UNAUTHENTICATED=false
# Comma-separated allowed browser origins for CORS. Empty means no Access-Control-Allow-Origin header.
MCP_ALLOWED_ORIGINS=
MCP_MAX_BODY_BYTES=16777216
MCP_MAX_BATCH_REQUESTS=50

# Feishu/Lark provider.
FEISHU_PROVIDER=feishu
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional: use a pre-provisioned token instead of app id/secret during local tests.
FEISHU_TENANT_ACCESS_TOKEN=

FEISHU_API_TIMEOUT_MS=15000
FEISHU_API_MAX_RETRIES=3
FEISHU_DOC_MAX_BLOCKS=3000
FEISHU_DOC_MAX_DEPTH=20
# For production write tests, set this to false only after checking app scopes and document permissions.
FEISHU_DOC_WRITE_DRY_RUN_DEFAULT=true

# Local skill registry. FEISHU_SKILLS_ENABLE_WRITE stays false unless write-capable skills are explicitly allowed.
FEISHU_SKILLS_DIRS=
FEISHU_SKILLS_ENABLE_WRITE=false

# Feishu/Lark endpoint templates. Keep configurable because document APIs evolve by tenant/version.
FEISHU_DOCX_METADATA_PATH_TEMPLATE=/open-apis/docx/v1/documents/%s
FEISHU_DOCX_CHILDREN_PATH_TEMPLATE=/open-apis/docx/v1/documents/%s/blocks/%s/children
FEISHU_DOCX_APPEND_CHILDREN_PATH_TEMPLATE=/open-apis/docx/v1/documents/%s/blocks/%s/children
FEISHU_DOCX_PERMISSION_PATH_TEMPLATE=/open-apis/drive/v1/permissions/%s/public?type=docx
FEISHU_FOLDER_PERMISSION_PATH_TEMPLATE=/open-apis/drive/v1/permissions/%s/public?type=folder
FEISHU_DOCX_CREATE_PATH=/open-apis/docx/v1/documents
FEISHU_DOCX_COMMENTS_PATH_TEMPLATE=/open-apis/drive/v1/files/%s/comments
FEISHU_DOCX_COMMENT_REPLIES_PATH_TEMPLATE=/open-apis/drive/v1/files/%s/comments/%s/replies
FEISHU_DOCX_COMMENT_RESOLVE_PATH_TEMPLATE=/open-apis/drive/v1/files/%s/comments/%s
FEISHU_WIKI_NODE_PATH_TEMPLATE=/open-apis/wiki/v2/spaces/get_node?token=%s
FEISHU_DRIVE_FILE_METADATA_PATH_TEMPLATE=/open-apis/drive/v1/files/%s

# User OAuth settings for authorization URL generation and future token storage.
FEISHU_OAUTH_REDIRECT_URI=
FEISHU_OAUTH_SCOPES=offline_access,docs:doc:readonly,docs:doc:write,drive:drive:readonly
FEISHU_OAUTH_STATE_SECRET=
FEISHU_OAUTH_AUTH_PATH=/open-apis/authen/v1/authorize
FEISHU_OAUTH_TOKEN_PATH=/open-apis/authen/v2/oauth/token
FEISHU_OAUTH_REFRESH_PATH=/open-apis/authen/v2/oauth/token
FEISHU_TOKEN_STORE_PATH=.data/feishu_tokens.json
# AES-GCM token store key (16, 24, or 32 bytes). Required by feishu-doc-mcp-http-server when token storage is enabled.
FEISHU_TOKEN_ENCRYPT_KEY=
